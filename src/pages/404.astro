---
import Layout from '../layouts/Layout.astro';
---
<Layout
  title="Page Not Found | Simon Bacon"
  description="The page you're looking for could not be found."
  canonical="https://simonbacon.com.au/404/"
>
  <Fragment slot="head">
    <meta name="robots" content="noindex" />
  </Fragment>

  <section class="section" style="padding-top: 8rem; text-align: center;">
    <div class="section-inner">
      <div class="gold-line" style="margin-left: auto; margin-right: auto;"></div>
      <h1 style="font-size: 3rem; margin-bottom: 1rem;">404</h1>
      <h2 class="section-title">Page Not Found</h2>
      <p style="color: var(--color-gray); max-width: 540px; margin: 0 auto 2rem;">
        The page you were looking for has moved or no longer exists. Try one of the links below.
      </p>
      <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center; margin-top: 2rem;">
        <a href="/" class="hero-cta">Home</a>
        <a href="/publications/" class="hero-cta">Publications</a>
        <a href="/contact/" class="hero-cta">Contact</a>
      </div>
    </div>
  </section>
</Layout>
